---
import Layout from '../../layouts/Layout.astro';

export const prerender = false;

const { slug } = Astro.params;
const SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbxnyPc9V26sGqtLUKTzIX7C-81rNaYYXO0TTIgB-Q3LPdQ6oRr5koFJeIjzPFQu2AVAeA/exec';

let post = null;
let allPosts = [];

try {
  // Fetch posts and increment view count for this specific slug in a single round-trip
  const apiRes = await fetch(`${SCRIPT_URL}?action=get_posts&slug=${encodeURIComponent(slug || '')}&_t=${Date.now()}`);
  const result = await apiRes.json();
  if (result.success && Array.isArray(result.data)) {
    allPosts = result.data;
    post = allPosts.find((p: any) => p.slug === slug);
  }
} catch (err) {
  console.error("Failed to load posts and increment views in SSR:", err);
}

if (!post) {
  return Astro.redirect('/404');
}

// Helper to decode basic HTML entities
function decodeHtmlEntities(str: string) {
  if (!str) return '';
  return str
    .replace(/&nbsp;/g, ' ')
    .replace(/&amp;/g, '&')
    .replace(/&lt;/g, '<')
    .replace(/&gt;/g, '>')
    .replace(/&quot;/g, '"')
    .replace(/&#039;/g, "'")
    .replace(/&#39;/g, "'")
    .replace(/&mdash;/g, '—')
    .replace(/&ndash;/g, '–');
}

// Clean HTML, strip tags, decode entities, normalize spaces
function cleanText(html: string) {
  if (!html) return '';
  const noTags = html.replace(/<[^>]*>/g, ' ');
  const decoded = decodeHtmlEntities(noTags);
  return decoded.replace(/\s+/g, ' ').trim();
}

// Helper to format proper ISO date strings for schemas
function toIsoDate(dateString: any) {
  if (!dateString) return new Date().toISOString();
  const d = new Date(dateString);
  return isNaN(d.getTime()) ? new Date().toISOString() : d.toISOString();
}

// Calculate meta details
const postTitle = post.title || 'Post';
let plainContent = 'Baca artikel lengkap di FanBlog.';
let wordCount = 0;
let readingTime = 1;

if (post.content) {
  const cleaned = cleanText(post.content);
  plainContent = cleaned.substring(0, 155);
  if (cleaned.length > 155) {
    plainContent = plainContent.trim() + '...';
  } else if (!plainContent) {
    plainContent = 'Baca artikel lengkap di FanBlog.';
  }
  wordCount = cleaned.split(/\s+/).filter(Boolean).length;
  readingTime = Math.ceil(wordCount / 225) || 1;
}

const host = Astro.url.host || 'fanblog.web.id';
const defaultThumb = `https://${host}/assets/img/logo.webp`;
let postThumbnail = defaultThumb;
if (post.thumbnail) {
  postThumbnail = post.thumbnail.startsWith('http') ? post.thumbnail : `https://${host}${post.thumbnail}`;
}

const canonicalUrl = `https://fanblog.web.id/post/${slug}`;

// Dynamic tags/keywords generation
const commonStopWords = ['dan', 'di', 'ke', 'dari', 'yang', 'untuk', 'atau', 'dengan', 'ini', 'itu', 'pada', 'adalah', 'yaitu', 'ialah', 'sebagai', 'cara', 'tips', 'panduan'];
const keywordsList = postTitle.toLowerCase()
  .replace(/[^\w\s]/g, '')
  .split(/\s+/)
  .filter((word: string) => word.length > 2 && !commonStopWords.includes(word));
const keywords = [...new Set([post.category, ...keywordsList])].slice(0, 10).join(', ');

const datePublishedIso = toIsoDate(post.created_at);
const dateModifiedIso = toIsoDate(post.updated_at || post.created_at);

const jsonLdGraph = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `https://${host}/#website`,
      "url": `https://${host}/`,
      "name": "FanBlog",
      "description": "Platform Berbagi Cerita dan Artikel Kreatif",
      "publisher": {
        "@id": `https://${host}/#organization`
      },
      "potentialAction": [
        {
          "@type": "SearchAction",
          "target": {
            "@type": "EntryPoint",
            "urlTemplate": `https://${host}/explore?q={search_term_string}`
          },
          "query-input": "required name=search_term_string"
        }
      ],
      "inLanguage": "id-ID"
    },
    {
      "@type": "Organization",
      "@id": `https://${host}/#organization`,
      "name": "FanBlog",
      "url": `https://${host}/`,
      "logo": {
        "@type": "ImageObject",
        "@id": `https://${host}/#logo`,
        "url": `https://${host}/assets/img/logo.webp`,
        "caption": "FanBlog Logo"
      },
      "image": {
        "@id": `https://${host}/#logo`
      }
    },
    {
      "@type": "WebPage",
      "@id": canonicalUrl,
      "url": canonicalUrl,
      "name": `${postTitle} - FanBlog`,
      "isPartOf": {
        "@id": `https://${host}/#website`
      },
      "primaryImageOfPage": {
        "@id": `${canonicalUrl}/#primaryimage`
      },
      "description": plainContent,
      "breadcrumb": {
        "@id": `${canonicalUrl}/#breadcrumb`
      },
      "inLanguage": "id-ID"
    },
    {
      "@type": "ImageObject",
      "@id": `${canonicalUrl}/#primaryimage`,
      "url": postThumbnail,
      "width": 1200,
      "height": 630
    },
    {
      "@type": "BreadcrumbList",
      "@id": `${canonicalUrl}/#breadcrumb`,
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": `https://${host}/`
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Blog",
          "item": `https://${host}/explore`
        },
        ...(post.category ? [{
          "@type": "ListItem",
          "position": 3,
          "name": post.category,
          "item": `https://${host}/explore?category=${encodeURIComponent(post.category)}`
        }] : []),
        {
          "@type": "ListItem",
          "position": post.category ? 4 : 3,
          "name": postTitle,
          "item": canonicalUrl
        }
      ]
    },
    {
      "@type": "BlogPosting",
      "@id": `${canonicalUrl}/#article`,
      "isPartOf": {
        "@id": canonicalUrl
      },
      "headline": postTitle,
      "description": plainContent,
      "image": {
        "@id": `${canonicalUrl}/#primaryimage`
      },
      "datePublished": datePublishedIso,
      "dateModified": dateModifiedIso,
      "mainEntityOfPage": canonicalUrl,
      "wordCount": wordCount,
      "timeRequired": `PT${readingTime}M`,
      "articleSection": [post.category],
      "keywords": keywords,
      "author": {
        "@type": "Person",
        "@id": `https://${host}/#author-${post.author_id}`,
        "name": post.author_name,
        "url": `https://${host}/profile?user=${post.author_id}`,
        "image": {
          "@type": "ImageObject",
          "url": post.author_avatar || `https://ui-avatars.com/api/?name=${encodeURIComponent(post.author_name)}&size=128`
        },
        "description": post.author_bio || "Konten Kreator di FanBlog"
      },
      "publisher": {
        "@id": `https://${host}/#organization`
      }
    }
  ]
};

const jsonLd = JSON.stringify(jsonLdGraph);

function formatDateServer(dateString: any) {
  if (!dateString) return '';
  const d = new Date(dateString);
  if (isNaN(d.getTime())) return dateString;

  const days = ['Minggu', 'Senin', 'Selasa', 'Rabu', 'Kamis', 'Jumat', 'Sabtu'];
  const dayName = days[d.getDay()];
  
  const day = String(d.getDate()).padStart(2, '0');
  const month = String(d.getMonth() + 1).padStart(2, '0');
  const year = d.getFullYear();
  
  const hours = String(d.getHours()).padStart(2, '0');
  const minutes = String(d.getMinutes()).padStart(2, '0');
  
  return `${dayName}, ${day}/${month}/${year} - ${hours}:${minutes} WIB`;
}

// Recommendation logic
let related = allPosts.filter((p: any) => p.id !== post.id && p.category === post.category);
let others = allPosts.filter((p: any) => p.id !== post.id && p.category !== post.category);

const shuffle = (array: any[]) => array.sort(() => Math.random() - 0.5);
shuffle(related);
shuffle(others);

let recommended = [...related, ...others].slice(0, 3);
---
<Layout>
  <Fragment slot="head">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{postTitle} - FanBlog</title>
    <link rel="icon" type="image/x-icon" href="/assets/img/favicon.ico">
    <meta name="description" content={plainContent}>
    <meta name="keywords" content={keywords}>
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
    <meta name="author" content={post.author_name}>
    
    <!-- Advanced Meta Crawl Directives -->
    <meta name="googlebot" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1">
    <meta name="bingbot" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1">
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="article">
    <meta property="og:locale" content="id_ID">
    <meta property="og:site_name" content="FanBlog">
    <meta property="og:url" content={canonicalUrl}>
    <meta property="og:title" content={postTitle}>
    <meta property="og:description" content={plainContent}>
    <meta property="og:image" content={postThumbnail}>
    <meta property="og:image:secure_url" content={postThumbnail}>
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:image:type" content="image/jpeg">
    <meta property="og:image:alt" content={postTitle}>
    
    <!-- Article Metadata -->
    <meta property="article:published_time" content={datePublishedIso}>
    <meta property="article:modified_time" content={dateModifiedIso}>
    <meta property="article:author" content={`https://${host}/profile?user=${post.author_id}`}>
    <meta property="article:section" content={post.category}>
    {keywordsList.slice(0, 5).map((tag: string) => (
      <meta property="article:tag" content={tag} />
    ))}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:site" content="@fanblog_id">
    <meta name="twitter:creator" content="@fanblog_id">
    <meta name="twitter:url" content={canonicalUrl}>
    <meta name="twitter:title" content={postTitle}>
    <meta name="twitter:description" content={plainContent}>
    <meta name="twitter:image" content={postThumbnail}>
    
    <link rel="canonical" href={canonicalUrl}>
    <script type="application/ld+json" id="structured-data" set:html={jsonLd}></script>
    <script type='text/javascript' src='https://platform-api.sharethis.com/js/sharethis.js#property=698357388ea334cc0e5b7c25&product=sop' async='async'></script>
    <script id="dsq-count-scr" src="//fanblog-6.disqus.com/count.js" async></script>
  


  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  
  <style>
    :root {
      --reading-font-size: 1.15rem;
      --reading-line-height: 1.85;
    }
    
    /* Reading Progress Bar */
    .progress-container {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 4px;
      background: transparent;
      z-index: 2000;
    }
    .progress-bar {
      height: 3px;
      background: var(--accent);
      width: 0%;
      transition: width 0.1s ease;
      opacity: 0.8;
    }

    .post-header { max-width: 850px; margin: 0 auto; text-align: center; padding: 2rem 0; }
    
    .post-content { 
      max-width: 800px; 
      margin: 0 auto; 
      font-size: var(--reading-font-size); 
      line-height: var(--reading-line-height); 
      color: var(--paragraph);
      font-weight: 400;
    }
    
    .post-content p { margin-bottom: 1.8rem; }
    
    .post-content h2 { font-size: 2rem; margin-top: 3rem; margin-bottom: 1.5rem; }
    .post-content h3 { font-size: 1.6rem; margin-top: 2.5rem; margin-bottom: 1.2rem; }
    
    .post-content img { 
      max-width: 100%; 
      height: auto; 
      border-radius: 16px; 
      margin: 2.5rem 0; 
      display: block;
    }

    .post-content blockquote {
      border-left: 4px solid var(--accent);
      padding: 1rem 2rem;
      margin: 2rem 0;
      background: rgba(79, 195, 247, 0.05);
      border-radius: 0 16px 16px 0;
      font-style: italic;
      font-size: 1.2rem;
      color: var(--headline);
    }

    .post-content code {
      background: rgba(255, 255, 255, 0.05);
      padding: 0.2rem 0.5rem;
      border-radius: 6px;
      font-size: 0.9em;
      color: var(--accent);
    }

    .post-content pre {
      background: var(--stroke);
      padding: 1.5rem;
      border-radius: 16px;
      overflow-x: auto;
      margin: 2rem 0;
      border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .post-content pre code {
      background: transparent;
      padding: 0;
      color: var(--headline);
    }

    .post-content ul, .post-content ol {
      margin-bottom: 1.8rem;
      padding-left: 1.5rem;
    }

    .post-content li {
      margin-bottom: 0.8rem;
    }

    .post-thumb-wrapper {
      box-shadow: 0 20px 40px rgba(0,0,0,0.3);
    }

    .post-thumbnail { 
      width: 100%; 
      max-height: 550px; 
      height: auto; 
      aspect-ratio: 16 / 9; 
      object-fit: cover; 
      object-position: center; 
      border-radius: 24px; 
      filter: contrast(1.05) brightness(1.02);
    }

    .author-box { 
      background: var(--card-bg); 
      border-radius: 24px; 
      padding: 2rem; 
      display: flex; 
      align-items: center; 
      gap: 1.5rem; 
      margin-top: 5rem; 
      border: 1px solid var(--stroke);
      transition: var(--transition);
    }
    
    .author-box:hover {
      transform: translateY(-5px);
      box-shadow: var(--shadow-hover);
    }

    /* Scroll to Top */
    #btn-back-to-top {
      position: fixed;
      bottom: 40px;
      right: 40px;
      display: none;
      z-index: 1000;
      width: 45px;
      height: 45px;
      border-radius: 14px;
      background: rgba(27, 32, 56, 0.8);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      color: var(--accent);
      border: 1px solid var(--stroke);
      box-shadow: var(--shadow-soft);
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      padding: 0;
      line-height: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.2rem;
      cursor: pointer;
    }
    
    #btn-back-to-top:hover {
      transform: translateY(-5px);
      background: var(--accent);
      color: var(--background);
      border-color: var(--accent);
      box-shadow: 0 10px 20px rgba(79, 195, 247, 0.3);
    }

    .breadcrumb {
      display: flex !important;
      align-items: center !important;
    }
    
    .breadcrumb-item {
      display: inline-flex !important;
      align-items: center !important;
    }

    .breadcrumb-item a {
      display: inline-flex !important;
      align-items: center !important;
      gap: 0.4rem !important;
      color: var(--paragraph);
      font-size: 0.9rem;
      text-decoration: none;
      opacity: 0.8;
    }
    
    .breadcrumb-item i {
      display: inline-flex !important;
      align-items: center !important;
      line-height: 1 !important;
    }
    
    .breadcrumb-item.active {
      display: inline-flex !important;
      align-items: center !important;
      color: var(--accent);
      font-size: 0.9rem;
    }

    /* Content reveal animation */
    #post-body {
      animation: fadeIn 0.8s ease-out forwards;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    @media (max-width: 768px) {
      .post-content { font-size: 1.1rem; }
      .post-header { padding: 1rem 0; }
      .post-header h1 { font-size: 1.8rem; }
      .author-box { flex-direction: column; text-align: center; padding: 1.5rem; }
      .author-box .d-flex {
        justify-content: center !important;
      }
      
      .post-meta-wrapper {
        flex-direction: column !important;
        gap: 0.5rem !important;
        font-size: 0.9rem;
      }
      .post-meta-wrapper .separator {
        display: none !important;
      }
      .breadcrumb {
        margin-bottom: 1rem !important;
      }
    }

    /* Recommendation Section Styles */
    .recommendation-section {
      margin-top: 6rem;
      border-top: 1px solid var(--stroke);
      padding-top: 4rem;
    }
    .recommendation-title {
      font-size: 1.8rem;
      margin-bottom: 2.5rem;
      display: flex;
      align-items: center;
      gap: 0.8rem;
    }
    .recommendation-title i {
      color: var(--accent);
    }
    .rec-card {
      height: 100%;
      transition: var(--transition);
      border: 1px solid transparent !important;
    }
    .rec-card:hover {
      border-color: var(--accent) !important;
      transform: translateY(-8px);
    }
    .rec-img-wrapper {
      position: relative;
      overflow: hidden;
      border-radius: 16px 16px 0 0;
    }
    .rec-img {
      height: 180px;
      width: 100%;
      object-fit: cover;
      transition: transform 0.5s ease;
    }
    .rec-card:hover .rec-img {
      transform: scale(1.1);
    }
    .rec-category {
      position: absolute;
      top: 1rem;
      left: 1rem;
      background: rgba(18, 22, 41, 0.7);
      backdrop-filter: blur(5px);
      padding: 0.3rem 0.8rem;
      border-radius: 8px;
      font-size: 0.75rem;
      color: var(--accent);
      font-weight: 600;
      z-index: 2; /* Ensure it stays above the stretched-link */
    }
  </style>
  </Fragment>

  <div class="progress-container">
    <div class="progress-bar" id="myBar"></div>
  </div>

  <main class="container my-5 min-vh-80" id="post-container">
    <nav aria-label="breadcrumb" style="max-width: 800px; margin: 0 auto 2rem;">
      <ol class="breadcrumb" itemscope itemtype="https://schema.org/BreadcrumbList">
        <li class="breadcrumb-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <a itemprop="item" href="/">
            <span itemprop="name"><i class="bi bi-house"></i> Home</span>
          </a>
          <meta itemprop="position" content="1" />
        </li>
        <li class="breadcrumb-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <a itemprop="item" href="/explore">
            <span itemprop="name">Blog</span>
          </a>
          <meta itemprop="position" content="2" />
        </li>
        {post.category && (
          <li class="breadcrumb-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <a itemprop="item" href={`/explore?category=${encodeURIComponent(post.category)}`}>
              <span itemprop="name">{post.category}</span>
            </a>
            <meta itemprop="position" content="3" />
          </li>
        )}
        <li class="breadcrumb-item active" aria-current="page" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <span itemprop="name">{postTitle.length > 30 ? postTitle.substring(0, 30) + '...' : postTitle}</span>
          <meta itemprop="position" content={post.category ? "4" : "3"} />
        </li>
      </ol>
    </nav>

    <div id="post-actions" class="text-end mb-3 d-flex justify-content-end gap-2" style="max-width: 800px; margin: 0 auto;"></div>

    <div class="post-header mb-4">
      <a href={`/explore?category=${encodeURIComponent(post.category)}`} id="category-link" class="text-decoration-none">
        <span class="badge bg-primary bg-opacity-10 text-primary mb-3 px-3 py-2 fs-6" id="post-category">{post.category}</span>
      </a>
      <h1 class="fw-bold display-4 mb-3" id="post-title">{post.title}</h1>
      <div class="d-flex align-items-center justify-content-center gap-3 text-muted mb-4 post-meta-wrapper">
        <a href={`/profile?user=${post.author_id}`} id="post-author-top" class="d-flex align-items-center gap-2 text-decoration-none text-muted hover-accent">
          <img src={post.author_avatar || `https://ui-avatars.com/api/?name=${encodeURIComponent(post.author_name)}&size=32`} 
               alt={post.author_name} 
               class="rounded-circle shadow-sm" 
               style="width: 28px; height: 28px; object-fit: cover; border: 1px solid var(--stroke);" 
               referrerpolicy="no-referrer" />
          <span>Oleh <strong class="text-white hover-accent">{post.author_name}</strong></span>
        </a>
        <span class="separator">&bull;</span>
        <span id="post-date">{formatDateServer(post.created_at)}</span>
        <span class="separator">&bull;</span>
        <span id="reading-time"><i class="bi bi-clock me-1"></i> {readingTime} mnt baca</span>
        <span class="separator">&bull;</span>
        <span id="post-views"><i class="bi bi-eye me-1"></i> {post.views || 0} kali dibaca</span>
      </div>
      <div class="sharethis-inline-share-buttons mb-4" data-url={canonicalUrl} data-title={postTitle}></div>
    </div>

    <div style="max-width: 850px; margin: 0 auto;" id="post-thumbnail-container">
      <div class="img-progressive post-thumb-wrapper loaded">
        <img src={postThumbnail} 
             class="post-thumbnail" 
             alt={post.title}
             data-fallback="/assets/img/logo.webp"
             referrerpolicy="no-referrer">
      </div>
    </div>

    <article class="post-content" id="post-body" set:html={post.content}></article>

    <div class="author-box mx-auto" style="max-width: 800px;">
      <img src={post.author_avatar || `https://ui-avatars.com/api/?name=${encodeURIComponent(post.author_name)}&size=128`} id="author-avatar" class="rounded-circle shadow-sm" style="width: 100px; height: 100px; object-fit: cover; border: 3px solid var(--stroke);" alt="Author">
      <div>
        <h5 class="fw-bold mb-1 fs-4" id="author-name">{post.author_name}</h5>
        <p class="text-muted mb-2" style="font-size: 1rem;" id="author-bio">{post.author_bio || 'Konten Kreator di FanBlog'}</p>
        <div class="d-flex gap-2">
          <a href={`/profile?user=${post.author_id}`} id="author-profile-link" class="btn btn-sm btn-outline-primary rounded-pill px-3">Lihat Profil</a>
        </div>
      </div>
    </div>

    <!-- Disqus Comment Section -->
    <div class="comments-section mx-auto my-5" style="max-width: 800px; background: var(--card-bg); border: 1px solid var(--stroke); border-radius: 24px; padding: 2.5rem; box-shadow: var(--shadow-soft);" data-aos="fade-up">
      <h3 class="fw-bold mb-4" style="color: var(--headline);"><i class="bi bi-chat-left-text me-2 text-primary"></i> Diskusi & Komentar</h3>
      <div id="disqus_thread" class="mt-4"></div>
    </div>

    <script is:inline define:vars={{ canonicalUrl, postId: post.id }}>
      var disqus_config = function () {
        this.page.url = canonicalUrl;
        this.page.identifier = postId;
      };
      (function() {
        var d = document, s = d.createElement('script');
        s.src = 'https://fanblog-6.disqus.com/embed.js';
        s.setAttribute('data-timestamp', +new Date());
        (d.head || d.body).appendChild(s);
      })();
    </script>
    <noscript>Please enable JavaScript to view the <a href="https://disqus.com/?ref_noscript">comments powered by Disqus.</a></noscript>

    <!-- Recommendation Section -->
    <div class="recommendation-section">
      <h3 class="recommendation-title fw-bold">
        <i class="bi bi-stars"></i> Rekomendasi Untuk Kamu
      </h3>
      <div class="row g-4" id="recommendations-container">
        {recommended.length === 0 ? (
          <div class="col-12 text-center text-muted">Belum ada rekomendasi artikel lainnya.</div>
        ) : (
          recommended.map(p => {
            const thumb = p.thumbnail || '/assets/img/logo.webp';
            return (
              <div class="col-md-4" data-aos="fade-up">
                <div class="card rec-card shadow-sm border-0">
                  <div class="rec-img-wrapper position-relative">
                    <span class="rec-category">{p.category}</span>
                    <div class="img-progressive rec-img-wrapper loaded">
                      <img src={thumb} class="rec-img" alt={p.title} loading="lazy" data-fallback="/assets/img/logo.webp" referrerpolicy="no-referrer" />
                    </div>
                  </div>
                  <div class="card-body p-3">
                    <h6 class="card-title fw-bold mb-2">
                      <a href={`/post/${p.slug}`} class="text-decoration-none text-white hover-accent stretched-link">
                        {p.title.length > 60 ? p.title.substring(0, 60) + '...' : p.title}
                      </a>
                    </h6>
                    <div class="d-flex align-items-center justify-content-between text-muted" style="font-size: 0.8rem;">
                      <a href={`/profile?user=${p.author_id}`} class="d-flex align-items-center gap-2 text-decoration-none text-muted hover-accent position-relative" style="z-index: 2;">
                        <img src={p.author_avatar || `https://ui-avatars.com/api/?name=${encodeURIComponent(p.author_name)}&size=32`} 
                             alt={p.author_name} 
                             class="rounded-circle" 
                             style="width: 20px; height: 20px; object-fit: cover;" 
                             referrerpolicy="no-referrer" />
                        <span class="hover-accent">{p.author_name}</span>
                      </a>
                      <div class="d-flex align-items-center gap-2">
                        <span>&bull;</span>
                        <span>{formatDateServer(p.created_at).split(',')[1]?.split('-')[0]?.trim() || ''}</span>
                        <span>&bull;</span>
                        <span class="d-flex align-items-center gap-1"><i class="bi bi-eye"></i> {p.views || 0}</span>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            )
          })
        )}
      </div>
    </div>
  </main>

  <button type="button" id="btn-back-to-top">
    <i class="bi bi-arrow-up"></i>
  </button>

  <Fragment slot="scripts">
    <script is:inline set:html={`window.postAuthorId = "${post.author_id}"; window.postId = "${post.id}";`} />
    <script is:inline>
    document.addEventListener('DOMContentLoaded', async () => {
      const user = Auth.getSession();
      const postAuthorId = window.postAuthorId;
      const postId = window.postId;

      if (user && (user.id === postAuthorId || user.role === 'admin')) {
        const postActions = document.getElementById('post-actions');
        if (postActions) {
          postActions.innerHTML = `
            <a href="/edit-post?id=${postId}" class="btn btn-outline-secondary"><i class="bi bi-pencil"></i> Edit</a>
            <button class="btn btn-outline-danger" onclick="deletePost('${postId}')"><i class="bi bi-trash"></i> Hapus</button>
          `;
        }
      }

      if (window.__sharethis__ && typeof window.__sharethis__.initialize === 'function') {
        window.__sharethis__.initialize();
      }

      window.onscroll = function() { scrollFunction() };

      function scrollFunction() {
        const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
        const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
        const scrolled = (winScroll / height) * 100;
        const myBar = document.getElementById("myBar");
        if (myBar) myBar.style.width = scrolled + "%";

        const mybutton = document.getElementById("btn-back-to-top");
        if (mybutton) {
          if (document.body.scrollTop > 20 || document.documentElement.scrollTop > 20) {
            mybutton.style.display = "block";
          } else {
            mybutton.style.display = "none";
          }
        }
      }

      const backToTop = document.getElementById("btn-back-to-top");
      if (backToTop) {
        backToTop.addEventListener("click", () => {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      }

      window.deletePost = async (id) => {
        const result = await Swal.fire({
          title: 'Apakah Anda yakin?',
          text: "Anda tidak akan dapat mengembalikan ini!",
          icon: 'warning',
          showCancelButton: true,
          confirmButtonColor: '#dc3545',
          confirmButtonText: 'Ya, hapus!',
          cancelButtonText: 'Batal'
        });

        if (result.isConfirmed) {
          const res = await API.deletePost(id, user.id);
          if (res.success) {
            showToast('success', 'Postingan dihapus');
            setTimeout(() => { window.location.href = '/'; }, 1000);
          } else {
            showToast('error', 'Error', res.message);
          }
        }
      };
    });
  </script>
  </Fragment>
</Layout>
