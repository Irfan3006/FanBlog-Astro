---
import Layout from '../layouts/Layout.astro';
---
<Layout>
  <Fragment slot="head">
    <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>404 Not Found - FanBlog</title>
  <link rel="icon" type="image/x-icon" href="/assets/img/favicon.ico">
  
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  </Fragment>

  <div class="text-center">
    <h1 class="display-1 fw-bold text-primary">404</h1>
    <h2 class="mb-4">Page Not Found</h2>
    <p class="text-muted mb-4">Halaman yang Anda cari mungkin telah dihapus, namanya telah diubah, atau sedang tidak tersedia untuk sementara waktu.</p>
    <a href="/" class="btn btn-primary px-4 py-2">Return Home</a>
  </div>

  <Fragment slot="scripts">
    
  </Fragment>
</Layout>
