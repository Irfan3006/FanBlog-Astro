---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <Fragment slot="head">
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>404 Not Found - FanBlog</title>
    <link rel="icon" type="image/x-icon" href="/assets/img/favicon.ico" />

    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  </Fragment>

  <div class="d-flex flex-column justify-content-center align-items-center text-center px-4" style="min-height: 70vh; max-width: 600px; margin: 0 auto;">
    <h1 class="display-1 fw-bold text-primary" style="font-size: 7rem; line-height: 1;">404</h1>
    <h2 class="mb-3 text-white fw-bold">Page Not Found</h2>
    <p class="text-muted mb-4 fs-5">
      Halaman yang Anda cari mungkin telah dihapus, namanya telah diubah, atau sedang tidak tersedia untuk sementara waktu.
    </p>
    <a href="/" class="btn btn-primary px-4 py-3 fw-bold rounded-pill shadow-lg"><i class="bi bi-house-door-fill me-2"></i>Return Home</a>
  </div>

  <Fragment slot="scripts"> </Fragment>
</Layout>
